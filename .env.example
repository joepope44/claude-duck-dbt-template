# Copy this file to .env and fill in your values
# .env is gitignored — never commit secrets

# DuckDB database paths (relative to dbt_claude_test/)
DBT_DEV_DB_PATH=dev.duckdb
DBT_PROD_DB_PATH=prod.duckdb

# dbt target (dev or prod)
DBT_TARGET=dev

# Optional: external data source credentials
# DATABASE_URL=
# API_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
